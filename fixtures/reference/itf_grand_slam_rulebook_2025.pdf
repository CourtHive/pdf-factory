        height: 50px;
        padding: 0 25px;
        background-color: transparent;
        color: #fff;
        border-color: #fff;
        margin: 0 auto;
        display: block;
    }
    #form-newsletter .onFormSubmittedFeedback {
        height: auto !important;
        background-color: transparent;
    }
    #form-newsletter .onFormSubmittedFeedbackMessage {
        color: #fff;
        font-weight: 900;
    }
    #form-newsletter button.onFormSubmittedFeedbackButtonSuccess {
        display: none;
    }
